---
import '~/styles/base.css';
import BrandMark from '~/components/BrandMark.astro';
import Galaxy from '~/components/Galaxy.astro';
import AmbientPlayer from '~/components/AmbientPlayer.astro';
import LetterForm from '~/components/LetterForm.astro';

interface Props {
  title: string;
  description?: string;
  /** When true, the galaxy renders in this page (default: true). */
  galaxy?: boolean;
  /** Body class hook for page-specific layout. */
  bodyClass?: string;
}
const {
  title,
  description = "Melody Jack — a small cosmology of writing. Slash, Nest, Build.",
  galaxy = true,
  bodyClass = '',
} = Astro.props;

const fullTitle = title === 'Melody Jack' ? title : `${title} — Melody Jack`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0814" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Melody Jack" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class={bodyClass}>
    {galaxy && <Galaxy />}
    <BrandMark />
    <main id="main">
      <slot />
    </main>
    <LetterForm pieceSlug="site" pieceTitle="Melody Jack" variant="dark" archetype="triune" />
    <AmbientPlayer />
  </body>
</html>
