---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import tarotLogic    from '~/assets/tarot/logic.png';
import tarotPsyche   from '~/assets/tarot/psyche.png';
import tarotInstinct from '~/assets/tarot/instinct.png';

// Pick three representative cards per archetype to anchor each
// mode's panel — the brief calls for "demonstrate not describe."
// Order is intentional: Instinct/Slash first (the body fires),
// then Psyche/Nest (it gets metabolized), then Logic/Build
// (the architecture is laid). The reader scrolls in the order
// the brief insists on: Instinct → Psyche → Logic.
const all = await getCollection('cards');

function pick(arch: 'logic' | 'psyche' | 'instinct', slugs: string[]) {
  return slugs
    .map((s) => all.find((c) => c.slug === s))
    .filter((c): c is NonNullable<typeof c> => Boolean(c));
}

const slashCards = pick('instinct', ['it-pleases-me', 'floor-with-rusty', 'have-you-ever-actually-rested']);
const nestCards  = pick('psyche',   ['compliment-or-stupid', 'on-the-spiral-sooner', 'the-soul-bond']);
const buildCards = pick('logic',    ['parenting-is-nudging', 'two-investment-banks', 'the-stopping-number']);

// Mode definitions — each with the brief's "what it is" /
// forms / diagnostic / failure-mode / rule. Used to render
// the in-place reveal when a mode panel is hovered/tapped.
type Form = { name: string; body: string };
type Mode = {
  id: 'slash' | 'nest' | 'build';
  archetype: 'instinct' | 'psyche' | 'logic';
  cognition: string;
  action: string;
  tagline: string;
  whatItIs: string;
  forms: Form[];
  diagnostic: string;
  schedule: string;
  failure: string;
  rule: string;
  cards: typeof slashCards;
  image: typeof tarotLogic;
  imageAlt: string;
};

const modes: Mode[] = [
  {
    id: 'slash',
    archetype: 'instinct',
    cognition: 'Instinct',
    action: 'Slash',
    tagline: 'Full immersion. Body-first. No audience.',
    whatItIs:
      'The mode where you are fully inside the thing. Body engaged, attention single-pointed, no part of you watching yourself do it. The hand moves before the mind explains why. You are not performing, not narrating, not optimizing — you are *in*. This is why deep work and playing on the floor with your toddler are the same mode. Slash requires the body to commit.',
    forms: [
      { name: 'Deep work',  body: 'Solo immersive labor; phone away, one named task.' },
      { name: 'Family',     body: 'On the floor, in the pool, fully present, no parallel screen.' },
      { name: 'Body',       body: 'Swimming, walking without input, drawing, hard physical skills.' },
      { name: 'Pleasure',   body: 'The genuine yes; food, music, rest that is actually rest.' },
    ],
    diagnostic:
      "Time disappears. The internal narrator goes quiet. You stop asking *am I doing this right.* When it ends, you're tired in a way that feels earned, not depleted.",
    schedule: '60–120 minute uninterrupted blocks, named by activity not category. One Slash per domain per day is the realistic target.',
    failure: 'Slash without Nest becomes reactivity. The body fires and never gets metabolized.',
    rule: 'Whatever is moving in you, let it move first. Name it after.',
    cards: slashCards,
    image: tarotInstinct,
    imageAlt: 'Instinct tarot card',
  },
  {
    id: 'nest',
    archetype: 'psyche',
    cognition: 'Psyche',
    action: 'Nest',
    tagline: 'The inner room where what moved gets metabolized.',
    whatItIs:
      'The mode where you sit with what just moved. Slash gave you experience; Nest is where experience becomes meaning. The inner voice meets what happened and decides whether to hold it kindly or against you. This is the mode that nearly every productivity culture skips, and the one most needed by people whose wiring puts them on the spiral early.',
    forms: [
      { name: 'Solo',           body: 'Journaling, walks without input, the morning hour before anyone wakes.' },
      { name: 'Co-regulation',  body: 'Long conversations with a soul bond or close friend where neither party is solving.' },
      { name: 'Therapeutic',    body: 'Therapy, ketamine therapy, the sessions that exist to metabolize what Slash turned up.' },
      { name: 'Witness',        body: 'Reading, gameplay, art doing your interior work for a moment so you can borrow it.' },
      { name: 'Repair',         body: 'The conversation with yourself after a mistake; being the kind adult to the kid in there.' },
    ],
    diagnostic:
      "You're not trying to fix anything. The inner voice is present but not punishing. You can name the feeling without immediately turning it into a task.",
    schedule: '30–60 minute bracketed quiet, daily ideally, weekly non-negotiably. Morning is best — before Slack, before logistics. A second Nest at 9–10 p.m. closes the day.',
    failure: 'Nest without Slash becomes rumination. Nest without Build becomes endless interior cartography that never reshapes anything outside you.',
    rule: 'Be the kind adult to yourself that you would be to your child.',
    cards: nestCards,
    image: tarotPsyche,
    imageAlt: 'Psyche tarot card',
  },
  {
    id: 'build',
    archetype: 'logic',
    cognition: 'Logic',
    action: 'Build',
    tagline: 'Architecture in service of the other two.',
    whatItIs:
      "The mode where you arrange the world — week, money, relationships, tools, house, career, kids' future — so that Slash and Nest can keep happening. Build is *not* the boss of the other modes. Build is in service to them. Logic is the architecture servant. A correctly built life makes the right Slash easy and the right Nest available.",
    forms: [
      { name: 'Career',        body: 'Long-arc thesis work, portfolio of impact, the promotion you don\'t ask for.' },
      { name: 'Relationship',  body: 'Active deposits, anniversary maintenance, friend-list curation.' },
      { name: 'Parenting',     body: 'Therapy structures, quality-time architecture, the grandpa-with-the-home-office endgame.' },
      { name: 'Money',         body: 'Debt strategy, mortgage path, the stopping number.' },
      { name: 'Creative',      body: 'Site architecture, publishing rhythm, the studio you\'re building toward.' },
      { name: 'Civic',         body: 'The architecture you build for strangers, because once you see something you owe it.' },
    ],
    diagnostic:
      "You're making decisions about future states. There's a clean satisfaction — *I just made something easier for future-me.* It feels slightly less alive than Slash and slightly less deep than Nest. That's correct.",
    schedule: 'Connective tissue. Sunday planning, Friday review, the 30 minutes of admin that buys 4 hours of deep work. Build is a frame, not a canvas.',
    failure: 'Build without Slash and Nest becomes the clean kitchen with no one in it. Optimization for an unspecified life. Efficiency theater.',
    rule: 'Build the world your Instinct can live in and your Psyche can rest in.',
    cards: buildCards,
    image: tarotLogic,
    imageAlt: 'Logic tarot card',
  },
];
---

<BaseLayout title="Melody Jack" bodyClass="page-zine">
  {/* HERO */}
  <section class="zine-hero">
    <p class="eyebrow">A small cosmology</p>
    <h1 class="zine-hero__title">
      <span>Melody</span>
      <span class="zine-hero__title-em">Jack</span>
    </h1>
    <p class="zine-hero__lede">
      Three modes of being. Two triads, one system.
      <em>Instinct fires first. Psyche metabolizes. Logic builds the architecture
      for the next round.</em> The order is fixed.
    </p>
    <p class="zine-hero__hint" aria-hidden="true">
      <span class="zine-hero__hint-arrow">↓</span> hover any card to read it
    </p>
  </section>

  {/* THREE MODE PANELS — Slash, Nest, Build */}
  <section class="zine-modes" aria-label="Slash, Nest, Build">
    {modes.map((m) => (
      <article class="mode" data-archetype={m.archetype} data-mode={m.id}>
        {/* The tarot card image is the centerpiece. The shine
            sweep + lift on hover is preserved from the existing
            TarotCard component, lifted inline to avoid a wrapper
            link (we don't navigate). */}
        <button
          type="button"
          class="mode__panel"
          aria-expanded="false"
          data-mode-toggle
        >
          <div class="mode__plate">
            <Image
              src={m.image}
              alt={m.imageAlt}
              widths={[420, 640, 920]}
              sizes="(min-width: 1080px) 28vw, (min-width: 720px) 40vw, 80vw"
              class="mode__plate-img"
              loading="eager"
            />
            <span class="mode__plate-glow" aria-hidden="true"></span>
            <span class="mode__plate-sheen" aria-hidden="true"></span>
          </div>

          <header class="mode__head">
            <p class="mode__cog" aria-hidden="true">{m.cognition}</p>
            <h2 class="mode__action">{m.action}</h2>
            <p class="mode__tag">{m.tagline}</p>
          </header>

          {/* The "rule, plainly" — visible at rest. The full
              body content reveals on hover/focus/tap. */}
          <p class="mode__rule">
            <span class="mode__rule-mark">¶</span>
            <span class="mode__rule-text">{m.rule}</span>
          </p>

          <div class="mode__chevron" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </button>

        {/* The reveal panel — opens on hover (desktop) or tap
            (mobile). Contains the full "what it is" body, the
            forms, diagnostic, schedule, and failure mode from
            the rebuild brief, plus three demonstrating cards. */}
        <div class="mode__reveal" data-mode-reveal>
          <div class="mode__reveal-inner">
            <div class="mode__reveal-prose">
              <p class="mode__reveal-what" set:html={m.whatItIs.replace(/\*([^*]+)\*/g, '<em>$1</em>')}></p>

              <dl class="mode__forms">
                {m.forms.map((f) => (
                  <div class="mode__form">
                    <dt>{f.name}</dt>
                    <dd>{f.body}</dd>
                  </div>
                ))}
              </dl>

              <div class="mode__bullets">
                <p><span class="mode__bullet-key">Diagnostic.</span> <span set:html={m.diagnostic.replace(/\*([^*]+)\*/g, '<em>$1</em>')}></span></p>
                <p><span class="mode__bullet-key">Schedule shape.</span> {m.schedule}</p>
                <p><span class="mode__bullet-key">Failure mode.</span> {m.failure}</p>
              </div>
            </div>

            <aside class="mode__demos" aria-label="Cards that demonstrate this mode">
              <p class="eyebrow mode__demos-eyebrow">From the notebook</p>
              <ul>
                {m.cards.map((c) => (
                  <li>
                    <a class="mode__demo" href={`/notebook#${c.slug}`}>
                      <span class="mode__demo-seed">{c.data.seed}</span>
                      <span class="mode__demo-foot">
                        <span class="mode__demo-aim">{c.data.aim}</span>
                        <span class="mode__demo-state">{c.data.state}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
              <a class="mode__demos-more" href="/notebook">
                See all in Loose Stars
                <svg viewBox="0 0 24 24" width="11" height="11" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </aside>
          </div>
        </div>
      </article>
    ))}
  </section>

  {/* INTEGRATION RIBBON */}
  <section class="zine-ribbon" aria-label="The integration">
    <p class="zine-ribbon__lines">
      <span>Slash is what you do when you're fully inside the thing.</span>
      <span>Nest is what you do with what the thing turned up.</span>
      <span>Build is what you arrange so the next thing can happen.</span>
    </p>
    <p class="zine-ribbon__creed">
      <em>Move. Hold. Architect.</em>
      <span class="zine-ribbon__sep" aria-hidden="true">·</span>
      In that order. Every day. For life.
    </p>
    <a class="zine-ribbon__cta" href="/notebook">
      Loose Stars — the working notebook
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>
</BaseLayout>

<script>
  /**
   * Mode-panel toggle. On desktop, hovering the panel pre-opens
   * the reveal; on mobile, tapping the panel toggles it. Either
   * way the reveal is in-place — there is no navigation.
   *
   * Multiple modes can be open at once. Tapping a mode that's
   * already open closes it.
   */
  function init() {
    const panels = document.querySelectorAll<HTMLElement>('.mode');
    panels.forEach((panel) => {
      const toggle = panel.querySelector<HTMLButtonElement>('[data-mode-toggle]');
      const reveal = panel.querySelector<HTMLElement>('[data-mode-reveal]');
      if (!toggle || !reveal) return;

      // Click toggles open/closed (mobile + keyboard).
      toggle.addEventListener('click', () => {
        const open = panel.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(open));
      });

      // Desktop hover — open while hovered, close when leaving.
      // Skipped on touch (no persistent cursor).
      let hoverTimer: ReturnType<typeof setTimeout> | null = null;
      panel.addEventListener('pointerenter', (e) => {
        if (e.pointerType === 'touch') return;
        if (hoverTimer) clearTimeout(hoverTimer);
        panel.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
      });
      panel.addEventListener('pointerleave', (e) => {
        if (e.pointerType === 'touch') return;
        // Small delay so the cursor can swing into the reveal
        // panel without it snapping closed underneath them.
        if (hoverTimer) clearTimeout(hoverTimer);
        hoverTimer = setTimeout(() => {
          panel.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
        }, 120);
      });
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>

<style>
  /* ============================================================
     ZINE FRONT PAGE — three tarot panels, hover/tap to reveal.
     The page sits over the galaxy background; each panel lives
     on its archetype color and uses one of the Desktop tarot
     images as its centerpiece.
     ============================================================ */
  .zine-hero {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 56ch;
    margin: 0 auto;
    padding: clamp(6rem, 12dvh, 9rem) clamp(1.25rem, 4vw, 3rem) clamp(2rem, 4dvh, 3rem);
  }
  .zine-hero__title {
    margin: 0.6rem 0 1rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw + 0.5rem, 4.75rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--warm-white);
  }
  .zine-hero__title span { display: inline-block; }
  .zine-hero__title-em {
    font-style: italic;
    margin-left: 0.35rem;
    background-image: linear-gradient(
      90deg,
      rgba(var(--instinct-glow), 0.95) 0%,
      rgba(var(--psyche-glow), 0.95)   33%,
      rgba(var(--logic-glow), 0.95)    66%,
      rgba(var(--instinct-glow), 0.95) 100%
    );
    background-size: 300% 100%;
    background-position: 0% 50%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 0.12em;
    animation: zine-title-sweep 14s linear infinite;
  }
  @keyframes zine-title-sweep {
    0%   { background-position:   0% 50%; }
    100% { background-position: 200% 50%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .zine-hero__title-em { animation: none; }
  }
  .zine-hero__lede {
    margin: 0 auto;
    max-width: 50ch;
    font-family: var(--font-serif);
    font-size: clamp(0.95rem, 0.5vw + 0.78rem, 1.08rem);
    line-height: 1.55;
    color: var(--warm-white-dim);
  }
  .zine-hero__lede em { color: var(--warm-white); font-style: italic; }
  .zine-hero__hint {
    margin-top: clamp(1.5rem, 3vh, 2.5rem);
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--warm-white-faint);
    display: inline-flex;
    align-items: center;
    gap: 0.65em;
  }
  .zine-hero__hint-arrow {
    display: inline-block;
    animation: hint-arrow 2.6s ease-in-out infinite;
  }
  @keyframes hint-arrow {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(4px); opacity: 1; }
  }

  /* ============================================================
     MODE PANELS
     ============================================================ */
  .zine-modes {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4dvh, 3rem) clamp(1rem, 4vw, 3rem) clamp(2rem, 4dvh, 3rem);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 2rem);
    align-items: stretch;
  }
  @media (max-width: 1024px) {
    .zine-modes { grid-template-columns: 1fr; gap: clamp(1.5rem, 3vh, 2.5rem); }
  }

  .mode {
    --acc-rgb: 201, 126, 85;
    --acc:     #c97e55;
    position: relative;
    isolation: isolate;
  }
  .mode[data-archetype='logic']    { --acc-rgb: var(--logic-glow);    --acc: rgb(var(--logic-glow)); }
  .mode[data-archetype='psyche']   { --acc-rgb: var(--psyche-glow);   --acc: rgb(var(--psyche-glow)); }
  .mode[data-archetype='instinct'] { --acc-rgb: var(--instinct-glow); --acc: rgb(var(--instinct-glow)); }

  /* The tarot panel button itself. */
  .mode__panel {
    width: 100%;
    text-align: left;
    background:
      linear-gradient(180deg,
        rgba(var(--acc-rgb), 0.06) 0%,
        rgba(8, 6, 14, 0.45) 100%);
    border: 1px solid rgba(var(--acc-rgb), 0.30);
    border-radius: 18px;
    padding: clamp(1.25rem, 2vw, 1.75rem);
    color: var(--warm-white);
    cursor: pointer;
    display: grid;
    grid-template-rows: auto auto auto auto;
    gap: 1rem;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    box-shadow:
      0 30px 60px -30px rgba(0, 0, 0, 0.7),
      0 0 24px -6px rgba(var(--acc-rgb), 0.18);
    transition:
      transform var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out),
      background var(--duration) var(--ease-out);
  }
  .mode.is-open .mode__panel,
  .mode__panel:hover,
  .mode__panel:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(var(--acc-rgb), 0.65);
    box-shadow:
      0 40px 80px -30px rgba(0, 0, 0, 0.75),
      0 0 36px -4px rgba(var(--acc-rgb), 0.30);
    outline: none;
  }

  /* Tarot plate — preserves the shine-sweep aesthetic from
     the previous TarotCard component but inlined here so the
     whole mode__panel acts as a single button. */
  .mode__plate {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.55;
    border-radius: 12px;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      0 24px 40px -16px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(var(--acc-rgb), 0.32),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    transform: translateZ(0);
    transition: transform 520ms var(--ease-out);
  }
  .mode__plate-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.4));
    transition: filter 520ms var(--ease-out), transform 520ms var(--ease-out);
  }
  /* Halo behind the plate — brightens on hover. */
  .mode__plate-glow {
    position: absolute;
    inset: -10%;
    z-index: -1;
    background: radial-gradient(
      ellipse at center,
      rgba(var(--acc-rgb), 0.45) 0%,
      rgba(var(--acc-rgb), 0.15) 35%,
      transparent 65%
    );
    opacity: 0.45;
    filter: blur(28px);
    transition: opacity 520ms var(--ease-out), transform 520ms var(--ease-out);
    pointer-events: none;
  }
  /* Sheen — a light pass that sweeps the plate on hover.
     Preserved from the previous tarot card behavior. */
  .mode__plate-sheen {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.20) 48%,
      transparent 60%
    );
    mix-blend-mode: overlay;
    opacity: 0;
    transform: translateX(-30%);
    transition: opacity 520ms var(--ease-out), transform 1100ms var(--ease-out);
  }
  .mode.is-open .mode__plate,
  .mode__panel:hover .mode__plate,
  .mode__panel:focus-visible .mode__plate {
    transform: translateY(-6px) scale(1.02);
  }
  .mode.is-open .mode__plate-glow,
  .mode__panel:hover .mode__plate-glow,
  .mode__panel:focus-visible .mode__plate-glow {
    opacity: 0.85;
    transform: scale(1.08);
  }
  .mode.is-open .mode__plate-sheen,
  .mode__panel:hover .mode__plate-sheen,
  .mode__panel:focus-visible .mode__plate-sheen {
    opacity: 1;
    transform: translateX(50%);
  }

  /* Header block — Cognition (eyebrow) · Action (title) · Tagline. */
  .mode__head {
    display: grid;
    gap: 0.4rem;
  }
  .mode__cog {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(var(--acc-rgb), 0.85);
  }
  .mode__action {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2rem, 2.4vw + 1.2rem, 2.85rem);
    line-height: 1;
    letter-spacing: -0.012em;
    color: var(--warm-white);
    text-shadow: 0 0 24px rgba(var(--acc-rgb), 0.32);
  }
  .mode__tag {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--warm-white-dim);
  }

  /* The "rule, plainly" — always visible. */
  .mode__rule {
    margin: 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.6em;
    padding: 0.85rem 1rem;
    border-left: 2px solid rgba(var(--acc-rgb), 0.55);
    background: rgba(var(--acc-rgb), 0.06);
    border-radius: 4px;
    font-family: var(--font-serif);
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--warm-white);
  }
  .mode__rule-mark {
    color: rgba(var(--acc-rgb), 0.85);
    font-style: italic;
    font-weight: 600;
  }
  .mode__rule-text { font-style: italic; }

  .mode__chevron {
    display: flex;
    justify-content: flex-end;
    color: rgba(var(--acc-rgb), 0.7);
    transition: transform var(--duration) var(--ease-out);
  }
  .mode.is-open .mode__chevron { transform: rotate(180deg); }

  /* THE REVEAL — opens in place. */
  .mode__reveal {
    margin-top: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 540ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .mode.is-open .mode__reveal {
    max-height: 3000px;  /* generous; content drives the actual height */
  }
  .mode__reveal-inner {
    display: grid;
