---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import tarotLogic    from '~/assets/tarot/logic.png';
import tarotPsyche   from '~/assets/tarot/psyche.png';
import tarotInstinct from '~/assets/tarot/instinct.png';

// Pick three representative cards per archetype to anchor each
// mode — the brief calls for "demonstrate, don't describe."
const all = await getCollection('cards');
function pick(slugs: string[]) {
  return slugs
    .map((s) => all.find((c) => c.slug === s))
    .filter((c): c is NonNullable<typeof c> => Boolean(c));
}
const slashCards = pick(['it-pleases-me', 'floor-with-rusty', 'have-you-ever-actually-rested']);
const nestCards  = pick(['compliment-or-stupid', 'on-the-spiral-sooner', 'the-soul-bond']);
const buildCards = pick(['parenting-is-nudging', 'two-investment-banks', 'the-stopping-number']);

type Form = { name: string; body: string };
type Mode = {
  id: 'slash' | 'nest' | 'build';
  archetype: 'instinct' | 'psyche' | 'logic';
  cognition: string;
  action: string;
  tagline: string;
  whatItIs: string;
  forms: Form[];
  diagnostic: string;
  schedule: string;
  failure: string;
  rule: string;
  cards: typeof slashCards;
  image: typeof tarotLogic;
  imageAlt: string;
};

const modes: Mode[] = [
  {
    id: 'slash',
    archetype: 'instinct',
    cognition: 'Instinct',
    action: 'Slash',
    tagline: 'Full immersion. Body-first. No audience.',
    whatItIs:
      'The mode where you are fully inside the thing. Body engaged, attention single-pointed, no part of you watching yourself do it. The hand moves before the mind explains why. You are not performing, not narrating, not optimizing — you are *in*.',
    forms: [
      { name: 'Deep work', body: 'Solo immersive labor; phone away, one named task.' },
      { name: 'Family',    body: 'On the floor, in the pool, fully present, no parallel screen.' },
      { name: 'Body',      body: 'Swimming, walking without input, drawing, hard physical skills.' },
      { name: 'Pleasure',  body: 'The genuine yes; food, music, rest that is actually rest.' },
    ],
    diagnostic:
      "Time disappears. The internal narrator goes quiet. You stop asking *am I doing this right.* When it ends, you're tired in a way that feels earned, not depleted.",
    schedule: '60–120 minute uninterrupted blocks, named by activity not category. One Slash per domain per day is the realistic target.',
    failure: 'Slash without Nest becomes reactivity. The body fires and never gets metabolized.',
    rule: 'Whatever is moving in you, let it move first. Name it after.',
    cards: slashCards,
    image: tarotInstinct,
    imageAlt: 'Instinct tarot card — Slash',
  },
  {
    id: 'nest',
    archetype: 'psyche',
    cognition: 'Psyche',
    action: 'Nest',
    tagline: 'The inner room where what moved gets metabolized.',
    whatItIs:
      'The mode where you sit with what just moved. Slash gave you experience; Nest is where experience becomes meaning. The inner voice meets what happened and decides whether to hold it kindly or against you.',
    forms: [
      { name: 'Solo',          body: 'Journaling, walks without input, the morning hour before anyone wakes.' },
      { name: 'Co-regulation', body: 'Long conversations with a soul bond or close friend where neither party is solving.' },
      { name: 'Therapeutic',   body: 'Therapy, the sessions that exist to metabolize what Slash turned up.' },
      { name: 'Witness',       body: 'Reading, gameplay, art doing your interior work for a moment so you can borrow it.' },
      { name: 'Repair',        body: 'The conversation with yourself after a mistake; being the kind adult to the kid in there.' },
    ],
    diagnostic:
      "You're not trying to fix anything. The inner voice is present but not punishing. You can name the feeling without immediately turning it into a task.",
    schedule: '30–60 minute bracketed quiet, daily ideally, weekly non-negotiably. Morning is best — before Slack, before logistics. A second Nest at 9–10 p.m. closes the day.',
    failure: 'Nest without Slash becomes rumination. Nest without Build becomes endless interior cartography that never reshapes anything outside you.',
    rule: 'Be the kind adult to yourself that you would be to your child.',
    cards: nestCards,
    image: tarotPsyche,
    imageAlt: 'Psyche tarot card — Nest',
  },
  {
    id: 'build',
    archetype: 'logic',
    cognition: 'Logic',
    action: 'Build',
    tagline: 'Architecture in service of the other two.',
    whatItIs:
      "The mode where you arrange the world — week, money, relationships, tools, house, career, kids' future — so that Slash and Nest can keep happening. Build is *not* the boss of the other modes. Build is in service to them. Logic is the architecture servant.",
    forms: [
      { name: 'Career',       body: "Long-arc thesis work, portfolio of impact, the promotion you don't ask for." },
      { name: 'Relationship', body: 'Active deposits, anniversary maintenance, friend-list curation.' },
      { name: 'Parenting',    body: 'Therapy structures, quality-time architecture, the grandpa-with-the-home-office endgame.' },
      { name: 'Money',        body: 'Debt strategy, mortgage path, the stopping number.' },
      { name: 'Creative',     body: "Site architecture, publishing rhythm, the studio you're building toward." },
      { name: 'Civic',        body: 'The architecture you build for strangers, because once you see something you owe it.' },
    ],
    diagnostic:
      "You're making decisions about future states. There's a clean satisfaction — *I just made something easier for future-me.* It feels slightly less alive than Slash and slightly less deep than Nest. That's correct.",
    schedule: 'Connective tissue. Sunday planning, Friday review, the 30 minutes of admin that buys 4 hours of deep work. Build is a frame, not a canvas.',
    failure: 'Build without Slash and Nest becomes the clean kitchen with no one in it. Optimization for an unspecified life. Efficiency theater.',
    rule: 'Build the world your Instinct can live in and your Psyche can rest in.',
    cards: buildCards,
    image: tarotLogic,
    imageAlt: 'Logic tarot card — Build',
  },
];
---

<BaseLayout title="Melody Jack" bodyClass="page-zine">
  {/* HERO */}
  <section class="zine-hero">
    <p class="eyebrow">A small cosmology</p>
    <h1 class="zine-hero__title">
      <span>Melody</span>
      <span class="zine-hero__title-em">Jack</span>
    </h1>
    <p class="zine-hero__lede">
      Three modes of being. Two triads, one system.
      <em>Instinct fires first. Psyche metabolizes. Logic builds the architecture
      for the next round.</em> The order is fixed.
    </p>
    <p class="zine-hero__hint" aria-hidden="true">
      <span class="zine-hero__hint-arrow">↓</span> hover any card to read it
    </p>
  </section>

  {/* THREE TAROT CARDS — Slash, Nest, Build */}
  <section class="zine-deck" aria-label="Slash, Nest, Build">
    {modes.map((m, i) => (
      <article class="card" data-archetype={m.archetype} data-mode={m.id} style={`--i:${i}`}>
        <button
          type="button"
          class="card__face"
          aria-haspopup="dialog"
          aria-expanded="false"
          aria-controls={`mode-reveal-${m.id}`}
          data-mode-toggle
        >
          {/* THE TAROT FRAME — full 1:1.7 card with the
              illustration filling it, an inner gilt border,
              the action title burned in at the foot, and
              the cognition label as a tiny eyebrow at the top. */}
          <div class="card__plate">
            <Image
              src={m.image}
              alt={m.imageAlt}
              widths={[420, 640, 920]}
              sizes="(min-width: 1080px) 28vw, (min-width: 720px) 40vw, 80vw"
              class="card__plate-img"
              loading="eager"
            />
            {/* Decorative gilt frame inside the plate edge —
                two corner brackets + a bottom panel for the title. */}
            <span class="card__plate-frame" aria-hidden="true"></span>
            <span class="card__plate-corner card__plate-corner--tl" aria-hidden="true"></span>
            <span class="card__plate-corner card__plate-corner--tr" aria-hidden="true"></span>
            <span class="card__plate-corner card__plate-corner--bl" aria-hidden="true"></span>
            <span class="card__plate-corner card__plate-corner--br" aria-hidden="true"></span>
            <span class="card__plate-glow" aria-hidden="true"></span>
            <span class="card__plate-sheen" aria-hidden="true"></span>

            {/* Title plaque burned into the bottom of the card */}
            <span class="card__plaque" aria-hidden="true">
              <span class="card__plaque-cog">{m.cognition}</span>
              <span class="card__plaque-action">{m.action}</span>
            </span>
          </div>

          {/* BELOW THE CARD — tagline, rule, hover hint */}
          <div class="card__caption">
            <p class="card__tag">{m.tagline}</p>
            <p class="card__rule">
              <span class="card__rule-mark" aria-hidden="true">¶</span>
              <span class="card__rule-text">{m.rule}</span>
            </p>
            <span class="card__hint">
              <span>read more</span>
              <svg viewBox="0 0 24 24" width="11" height="11" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </button>

        {/* THE READING — opens to the side as a tarot reading
            panel: the full mode body. On wide viewports it
            slides out to the right of the card; on narrow it
            stacks below. Either way, in-place — no
            navigation, no full-page modal. */}
        <aside
          class="card__reading"
          id={`mode-reveal-${m.id}`}
          data-mode-reveal
          aria-hidden="true"
        >
          <header class="card__reading-head">
            <p class="card__reading-eyebrow">
              {m.cognition} <span class="card__reading-arrow">→</span> {m.action}
            </p>
            <h3 class="card__reading-title">{m.tagline}</h3>
          </header>

          <p class="card__reading-what" set:html={m.whatItIs.replace(/\*([^*]+)\*/g, '<em>$1</em>')}></p>

          <dl class="card__reading-forms">
            {m.forms.map((f) => (
              <div class="card__reading-form">
                <dt>{f.name}</dt>
                <dd>{f.body}</dd>
              </div>
            ))}
          </dl>

          <div class="card__reading-bullets">
            <p><span class="card__reading-key">Diagnostic.</span> <span set:html={m.diagnostic.replace(/\*([^*]+)\*/g, '<em>$1</em>')}></span></p>
            <p><span class="card__reading-key">Schedule shape.</span> {m.schedule}</p>
            <p><span class="card__reading-key">Failure mode.</span> {m.failure}</p>
          </div>

          <div class="card__reading-demos">
            <p class="card__reading-demos-eyebrow">From the notebook</p>
            <ul>
              {m.cards.map((c) => (
                <li>
                  <a class="card__reading-demo" href={`/notebook#${c.slug}`}>
                    <span class="card__reading-demo-seed">{c.data.seed}</span>
                    <span class="card__reading-demo-foot">
                      <span class="card__reading-demo-aim">{c.data.aim}</span>
                      <span class="card__reading-demo-state">{c.data.state}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </article>
    ))}
  </section>

  {/* INTEGRATION RIBBON */}
  <section class="zine-ribbon" aria-label="The integration">
    <p class="zine-ribbon__lines">
      <span>Slash is what you do when you're fully inside the thing.</span>
      <span>Nest is what you do with what the thing turned up.</span>
      <span>Build is what you arrange so the next thing can happen.</span>
    </p>
    <p class="zine-ribbon__creed">
      <em>Move. Hold. Architect.</em>
      <span class="zine-ribbon__sep" aria-hidden="true">·</span>
      In that order. Every day. For life.
    </p>
    <a class="zine-ribbon__cta" href="/notebook">
      Loose Stars — the working notebook
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>
</BaseLayout>

<script>
  /**
   * Each mode card has a click-to-toggle reading panel and a
   * hover-to-preview behavior on desktop. Multiple readings
   * can be open at once. The reveal slides in beside the
   * card on wide viewports and below it on narrow.
   */
  function init() {
    document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
      const toggle = card.querySelector<HTMLButtonElement>('[data-mode-toggle]');
      const reveal = card.querySelector<HTMLElement>('[data-mode-reveal]');
      if (!toggle || !reveal) return;

      function setOpen(open: boolean) {
        card.classList.toggle('is-open', open);
        toggle!.setAttribute('aria-expanded', String(open));
        reveal!.setAttribute('aria-hidden', String(!open));
      }

      toggle.addEventListener('click', () => {
        setOpen(!card.classList.contains('is-open'));
      });

      // Desktop hover — open while hovered (with a small grace
      // period so the cursor can swing into the reading panel
      // without it snapping closed).
      let hoverTimer: ReturnType<typeof setTimeout> | null = null;
      card.addEventListener('pointerenter', (e) => {
        if (e.pointerType === 'touch') return;
        if (hoverTimer) clearTimeout(hoverTimer);
        setOpen(true);
      });
      card.addEventListener('pointerleave', (e) => {
        if (e.pointerType === 'touch') return;
        if (hoverTimer) clearTimeout(hoverTimer);
        hoverTimer = setTimeout(() => setOpen(false), 150);
      });
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>

<style>
  /* ============================================================
     ZINE — three tarot cards on a starlit table.
     The cards are the load-bearing object: each one rendered as
     a full 1:1.7 tarot card, gilt frame, action title burned
     into a plaque at the foot, the artwork running its full
     length without crop. Hover reveals the reading panel
     beside the card.
     ============================================================ */
  .zine-hero {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 56ch;
    margin: 0 auto;
    padding: clamp(5rem, 10dvh, 8rem) clamp(1.25rem, 4vw, 3rem) clamp(2rem, 4dvh, 3rem);
  }
  .zine-hero__title {
    margin: 0.6rem 0 1rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw + 0.5rem, 4.75rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--warm-white);
  }
  .zine-hero__title span { display: inline-block; }
  .zine-hero__title-em {
    font-style: italic;
    margin-left: 0.35rem;
    background-image: linear-gradient(
      90deg,
      rgba(var(--instinct-glow), 0.95) 0%,
      rgba(var(--psyche-glow), 0.95)   33%,
      rgba(var(--logic-glow), 0.95)    66%,
      rgba(var(--instinct-glow), 0.95) 100%
    );
    background-size: 300% 100%;
    background-position: 0% 50%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 0.12em;
    animation: zine-title-sweep 14s linear infinite;
  }
  @keyframes zine-title-sweep {
    0%   { background-position:   0% 50%; }
    100% { background-position: 200% 50%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .zine-hero__title-em { animation: none; }
  }
  .zine-hero__lede {
    margin: 0 auto;
    max-width: 50ch;
    font-family: var(--font-serif);
    font-size: clamp(0.95rem, 0.5vw + 0.78rem, 1.08rem);
    line-height: 1.55;
    color: var(--warm-white-dim);
  }
  .zine-hero__lede em { color: var(--warm-white); font-style: italic; }
  .zine-hero__hint {
    margin-top: clamp(1.5rem, 3vh, 2.5rem);
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--warm-white-faint);
    display: inline-flex;
    align-items: center;
    gap: 0.65em;
  }
  .zine-hero__hint-arrow {
    display: inline-block;
    animation: hint-arrow 2.6s ease-in-out infinite;
  }
  @keyframes hint-arrow {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(4px); opacity: 1; }
  }

  /* ============================================================
     THE DECK — three tarot cards on a single horizontal axis.
     We use a flex row so the readings can grow rightward when
     opened on wide screens; on narrow screens the deck stacks.
     ============================================================ */
  .zine-deck {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4dvh, 3rem) clamp(1.25rem, 4vw, 3rem) clamp(1.5rem, 3dvh, 2.5rem);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }
  @media (max-width: 1024px) {
    .zine-deck { grid-template-columns: 1fr; gap: clamp(2rem, 4vh, 3rem); }
  }

  .card {
    --acc-rgb: 201, 126, 85;
    --acc:     #c97e55;
    position: relative;
    isolation: isolate;
  }
  .card[data-archetype='logic']    { --acc-rgb: var(--logic-glow);    --acc: rgb(var(--logic-glow)); }
  .card[data-archetype='psyche']   { --acc-rgb: var(--psyche-glow);   --acc: rgb(var(--psyche-glow)); }
  .card[data-archetype='instinct'] { --acc-rgb: var(--instinct-glow); --acc: rgb(var(--instinct-glow)); }

  .card__face {
    width: 100%;
    text-align: left;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    display: grid;
    gap: clamp(1rem, 2vh, 1.4rem);
    color: var(--warm-white);
  }
  .card__face:focus-visible { outline: none; }

  /* THE TAROT PLATE — true tarot card aspect (1:1.7), the
     full illustration visible (object-fit: contain on a tinted
     paper backplate so the art floats inside its frame),
     gilt corners, and an action plaque burned into the bottom.
     The artwork has the SAME aspect on disk (1:2 portrait),
     and `contain` on a 1:1.7 frame leaves a tiny letterbox
     band at the top + bottom that the corner brackets and
     plaque sit on. */
  .card__plate {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.7;
    border-radius: 14px;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(
        ellipse at center,
        rgba(var(--acc-rgb), 0.20) 0%,
        rgba(8, 6, 14, 0.85) 70%
      );
    border: 1px solid rgba(var(--acc-rgb), 0.45);
    box-shadow:
      0 30px 60px -28px rgba(0, 0, 0, 0.85),
      0 0 0 1px rgba(0, 0, 0, 0.4) inset,
      0 0 28px rgba(var(--acc-rgb), 0.25);
    transition:
      transform 540ms var(--ease-out),
      box-shadow 540ms var(--ease-out),
      border-color 540ms var(--ease-out);
  }
  .card.is-open .card__plate,
  .card__face:hover .card__plate,
  .card__face:focus-visible .card__plate {
    transform: translateY(-6px);
    border-color: rgba(var(--acc-rgb), 0.85);
    box-shadow:
      0 40px 80px -28px rgba(0, 0, 0, 0.85),
      0 0 36px rgba(var(--acc-rgb), 0.42),
      0 0 0 1px rgba(0, 0, 0, 0.4) inset;
  }
  .card__plate-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  /* Decorative inner frame — a thin gilt rule traced inside
     the plate edge, with extra weight on top + bottom panels. */
  .card__plate-frame {
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(var(--acc-rgb), 0.55);
    border-radius: 10px;
    pointer-events: none;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
  }
  /* Corner brackets — short bars in each corner of the plate. */
  .card__plate-corner {
    position: absolute;
    width: 22px;
    height: 22px;
    color: rgba(var(--acc-rgb), 0.95);
    pointer-events: none;
  }
  .card__plate-corner::before,
  .card__plate-corner::after {
    content: '';
    position: absolute;
    background: currentColor;
    box-shadow: 0 0 8px rgba(var(--acc-rgb), 0.55);
  }
  .card__plate-corner::before { width: 100%; height: 1.5px; }
  .card__plate-corner::after  { width: 1.5px; height: 100%; }
  .card__plate-corner--tl { top: 16px; left: 16px; }
  .card__plate-corner--tl::before { top: 0; left: 0; }
  .card__plate-corner--tl::after  { top: 0; left: 0; }
  .card__plate-corner--tr { top: 16px; right: 16px; }
  .card__plate-corner--tr::before { top: 0; right: 0; }
  .card__plate-corner--tr::after  { top: 0; right: 0; }
  .card__plate-corner--bl { bottom: 16px; left: 16px; }
  .card__plate-corner--bl::before { bottom: 0; left: 0; }
  .card__plate-corner--bl::after  { bottom: 0; left: 0; }
  .card__plate-corner--br { bottom: 16px; right: 16px; }
  .card__plate-corner--br::before { bottom: 0; right: 0; }
  .card__plate-corner--br::after  { bottom: 0; right: 0; }

  /* Halo behind the plate — brightens on hover. */
  .card__plate-glow {
    position: absolute;
    inset: -8%;
    z-index: -1;
    background: radial-gradient(
      ellipse at center,
      rgba(var(--acc-rgb), 0.42) 0%,
      rgba(var(--acc-rgb), 0.10) 35%,
      transparent 65%
    );
    opacity: 0.35;
    filter: blur(28px);
    transition: opacity 540ms var(--ease-out), transform 540ms var(--ease-out);
    pointer-events: none;
  }
  .card.is-open .card__plate-glow,
  .card__face:hover .card__plate-glow,
  .card__face:focus-visible .card__plate-glow {
    opacity: 0.85;
    transform: scale(1.08);
  }
  /* Sheen — the diagonal light pass that sweeps across the plate
     on hover. Preserved from the previous TarotCard component. */
  .card__plate-sheen {
    position: absolute;
    inset: 0;
    z-index: 3;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.20) 48%,
      transparent 60%
    );
    mix-blend-mode: overlay;
    opacity: 0;
    transform: translateX(-30%);
    transition: opacity 600ms var(--ease-out), transform 1100ms var(--ease-out);
  }
  .card.is-open .card__plate-sheen,
  .card__face:hover .card__plate-sheen,
  .card__face:focus-visible .card__plate-sheen {
    opacity: 1;
    transform: translateX(50%);
  }

  /* The action plaque burned into the bottom of the card —
     the cognition (small caps eyebrow) above the action
     (italic display title). */
  .card__plaque {
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: 6%;
    z-index: 4;
    text-align: center;
    pointer-events: none;
    padding: 0.55rem 0.8rem 0.65rem;
    background:
      linear-gradient(
        180deg,
        rgba(8, 6, 14, 0.0) 0%,
        rgba(8, 6, 14, 0.78) 35%,
        rgba(8, 6, 14, 0.92) 100%
      );
    border-top: 1px solid rgba(var(--acc-rgb), 0.55);
    box-shadow: 0 -10px 24px rgba(8, 6, 14, 0.35);
  }
  .card__plaque-cog {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(var(--acc-rgb), 0.92);
