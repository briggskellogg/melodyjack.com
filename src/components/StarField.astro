---
/**
 * StarField — a zoomed-in night sky for the notebook page.
 *
 * No spiral, no rotation, no central core. Just a dense
 * uniformly-distributed field of stars covering the whole
 * viewport, with three star "weights" (most are tiny,
 * some are mid, a handful are bright with halos), gentle
 * twinkle on a fraction of them, and a very slow upward
 * drift so the field feels alive without ever pulling the
 * eye off the cards.
 *
 * The reader feels like the cards are floating among the
 * stars — the previous /notebook had this look and it's the
 * one to bring back.
 */
---

<div class="starfield" aria-hidden="true">
  {/* Faint atmospheric tint pools — nothing geometric, just a
      hint of color depth so the field doesn't read as a
      uniform black box. */}
  <div class="starfield__pool starfield__pool--violet"></div>
  <div class="starfield__pool starfield__pool--cool"></div>
  <canvas class="starfield__canvas" id="starfieldCanvas"></canvas>
  <div class="starfield__vignette" aria-hidden="true"></div>
</div>

<script>
  function init() {
    const canvas = document.getElementById('starfieldCanvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    /**
     * Star density: targeted star count is derived from area so
     * the field never looks sparse on a wide monitor or
     * over-dense on a phone. ~1 star per 1500 px² gives a rich
     * but uncluttered sky; cap so absurd resolutions don't
     * blow the budget.
     */
    const STARS_PER_PX2 = 1 / 1500;
    const MAX_STARS = 1800;

    type Star = {
      x: number;       // px
      y: number;       // px
      size: number;    // radius (px)
      base: number;    // base alpha
      tint: string;    // 'r,g,b'
      amp: number;     // twinkle alpha amplitude
      twFreq: number;
      twPhase: number;
      vy: number;      // vertical drift (px/sec, negative = up)
    };

    let stars: Star[] = [];
    let dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
    let w = 0, h = 0;
    let last = performance.now();

    const tints = [
      '255, 252, 245',  // soft white (most stars)
      '255, 252, 245',
      '255, 252, 245',
      '218, 230, 255',  // cool blue
      '218, 230, 255',
      '255, 232, 200',  // soft warm
      '255, 215, 180',  // warm gold (rare)
    ];

    function rand(min: number, max: number) {
      return min + Math.random() * (max - min);
    }

    function seedStars() {
      stars = [];
      const target = Math.min(MAX_STARS, Math.round(w * h * STARS_PER_PX2));
      for (let i = 0; i < target; i++) {
        // Three weight buckets:
        //   85%: tiny twinkle (size 0.4–0.9, dim)
        //   12%: mid (size 0.9–1.5, brighter)
        //    3%: bright with halo (size 1.6–2.4)
        const r = Math.random();
        let size: number;
        let base: number;
        if (r < 0.85) {
          size = rand(0.4, 0.9);
          base = rand(0.18, 0.50);
        } else if (r < 0.97) {
          size = rand(0.9, 1.5);
          base = rand(0.45, 0.75);
        } else {
          size = rand(1.6, 2.4);
          base = rand(0.65, 0.95);
        }
        const willTwinkle = Math.random() < 0.30;
        stars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          size,
          base,
          tint: tints[Math.floor(Math.random() * tints.length)],
          amp: willTwinkle ? rand(0.15, 0.30) : 0,
          twFreq: rand(0.2, 0.7),
          twPhase: Math.random() * Math.PI * 2,
          // Very slow upward drift (1–3 px/sec). The field
          // wraps when stars exit the top so it never empties.
          vy: -rand(0.6, 2.4),
        });
      }
    }

    function resize() {
      const rect = canvas!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas!.width  = Math.round(w * dpr);
      canvas!.height = Math.round(h * dpr);
      canvas!.style.width = `${w}px`;
      canvas!.style.height = `${h}px`;
    }

    function draw(now: number, dt: number) {
      const tSec = now / 1000;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx!.clearRect(0, 0, w, h);
      for (let i = 0; i < stars.length; i++) {
        const s = stars[i];
        s.y += s.vy * dt;
        // Wrap when the star drifts off the top edge.
        if (s.y < -8) {
          s.y = h + 8;
          s.x = Math.random() * w;
        }

        const a = s.amp === 0
          ? s.base
          : Math.max(0.04, Math.min(1,
              s.base + s.amp * Math.sin(tSec * s.twFreq * Math.PI * 2 + s.twPhase)));

        if (s.size > 1.5) {
          // Halo on the brightest stars.
          const halo = ctx!.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.size * 4.5);
          halo.addColorStop(0, `rgba(${s.tint}, ${a * 0.55})`);
          halo.addColorStop(1, `rgba(${s.tint}, 0)`);
          ctx!.fillStyle = halo;
          ctx!.beginPath();
          ctx!.arc(s.x, s.y, s.size * 4.5, 0, Math.PI * 2);
          ctx!.fill();
        }
        ctx!.fillStyle = `rgba(${s.tint}, ${a})`;
        ctx!.beginPath();
        ctx!.arc(s.x, s.y, s.size, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    function tick(now: number) {
      const dt = Math.min(0.05, (now - last) / 1000);
      last = now;
      draw(now, dt);
      requestAnimationFrame(tick);
    }

    function setup() {
      dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      resize();
      seedStars();
      last = performance.now();
      draw(last, 0);
    }
    setup();

    let resizeT: number | undefined;
    window.addEventListener('resize', () => {
      if (resizeT) window.clearTimeout(resizeT);
      resizeT = window.setTimeout(setup, 150);
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) requestAnimationFrame(tick);
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background:
      radial-gradient(ellipse 90% 80% at 50% 30%, rgba(40, 30, 70, 0.40) 0%, transparent 70%),
      linear-gradient(180deg, #0a0814 0%, #06050f 60%, #02020a 100%);
  }
  /* Two atmospheric color pools so the field has a hint of
     depth — never bright enough to compete with the cards. */
  .starfield__pool {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    mix-blend-mode: screen;
    pointer-events: none;
  }
  .starfield__pool--violet {
    width: 90vmax;
    height: 90vmax;
    top: -25vmax;
    left: -20vmax;
    background: radial-gradient(circle, rgba(150, 100, 220, 0.18) 0%, rgba(150, 100, 220, 0) 60%);
    animation: sf-drift-a 130s ease-in-out infinite alternate;
  }
  .starfield__pool--cool {
    width: 80vmax;
    height: 80vmax;
    bottom: -22vmax;
    right: -18vmax;
    background: radial-gradient(circle, rgba(95, 130, 220, 0.18) 0%, rgba(95, 130, 220, 0) 60%);
    animation: sf-drift-b 150s ease-in-out infinite alternate;
  }
  @keyframes sf-drift-a { from { transform: translate3d(0,0,0); } to { transform: translate3d(6vmax, 4vmax, 0); } }
  @keyframes sf-drift-b { from { transform: translate3d(0,0,0); } to { transform: translate3d(-5vmax, -6vmax, 0); } }

  .starfield__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .starfield__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 90% 80% at 50% 50%,
      transparent 60%,
      rgba(0, 0, 0, 0.45) 100%
    );
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .starfield__pool { animation: none; }
  }
</style>
